{%- comment -%}
  Custom 2-level variant UI (dropdown-component). Optional "Custom size" width value adds dimension fields → line item properties.
  Create a variant per Printed Side with Width = the configured custom option name (default "Custom size").
{%- endcomment -%}
{%- liquid
  assign opt1 = product.options[0]
  assign opt2 = product.options[1]
  assign custom_size_o2 = custom_size_option_value | default: 'Custom size'
-%}
{{- 'product-custom-cascade-variants.css' | asset_url | stylesheet_tag -}}

<script id="CustomVariantsFull-{{ section.id }}" type="application/json">
  {{- product.variants | json -}}
</script>

<div
  class="product-custom-cascade-ui"
  data-cascade-root="{{ section.id }}"
  data-cascade-custom-o2="{{ custom_size_o2 | escape }}"
  data-json-selector="{{ product_json_id | prepend: '#' }}"
  data-forms='["#{{ product_form_installment_id }}", "#{{ form_id }}"]'
  data-renders='["[{{ stock_render_attr }}]", "[{{ price_render_attr }}]", "[{{ sku_render_attr }}]", "[{{ price_unit_render_attr }}]", "[{{ share_render_attr }}]", "[{{ qty_render_attr }}]", "[{{ pickup_render_attr }}]", "[{{ stockbar_render_attr }}]"]'
  data-section-id="{{ section.id }}"
  data-product-url="{{ product.url }}"
  data-main-parent="#{{ section.id }}-description"
  data-galleries='["[{{ media_slider_attr }}]", "[{{ media_static_attr }}]"]'
  data-error-selector="[{{ error_render_attr }}]"
  data-update-url="true"
>
  <div class="product-variant_row product-custom-cascade_field">
    <div class="product-variant_title-wrap --v-align-middle product-custom-cascade_title">
      <label
        class="product-common_variant-title text-size--medium --fw-bold h"
        id="cascade-heading-1-{{ section.id }}"
        for="cascade-opt1-btn-{{ section.id }}"
      >
        {{- opt1 | escape -}}:
      </label>
    </div>
    <div class="dropdown-component dropdown-component--variant product-custom-cascade_dd">
      <dropdown-component>
        <button
          type="button"
          id="cascade-opt1-btn-{{ section.id }}"
          class="dropdown-component_opener dropdown-variant_opener --align-left --word-break"
          aria-expanded="false"
          aria-haspopup="listbox"
          aria-controls="cascade-opt1-list-{{ section.id }}"
          aria-labelledby="cascade-heading-1-{{ section.id }}"
        >
          <span class="product-custom-cascade_dd-value" data-cascade-opener="1"></span>
          <i class="dropdown-componenet_icn-caret" aria-hidden="true">
            {%- render 'icons-data',
              width: 9,
              height: 5,
              use_icon: true,
              icon_reference: 'chevron-down',
              section_id: section.id
            -%}
          </i>
        </button>
        <div class="dropdown-component_wrapper dropdown-variant_wrapper" tabindex="-1">
          <ul
            id="cascade-opt1-list-{{ section.id }}"
            class="list-unstyled dropdown-variant_items --align-left"
            role="listbox"
            data-cascade-list="1"
          ></ul>
        </div>
      </dropdown-component>
    </div>
  </div>

  <div class="product-variant_row product-custom-cascade_field">
    <div class="product-variant_title-wrap --v-align-middle product-custom-cascade_title">
      <label
        class="product-common_variant-title text-size--medium --fw-bold h"
        id="cascade-heading-2-{{ section.id }}"
        for="cascade-opt2-btn-{{ section.id }}"
      >
        {{- opt2 | escape -}}:
      </label>
    </div>
    <div class="dropdown-component dropdown-component--variant product-custom-cascade_dd">
      <dropdown-component>
        <button
          type="button"
          id="cascade-opt2-btn-{{ section.id }}"
          class="dropdown-component_opener dropdown-variant_opener --align-left --word-break"
          aria-expanded="false"
          aria-haspopup="listbox"
          aria-controls="cascade-opt2-list-{{ section.id }}"
          aria-labelledby="cascade-heading-2-{{ section.id }}"
        >
          <span class="product-custom-cascade_dd-value" data-cascade-opener="2"></span>
          <i class="dropdown-componenet_icn-caret" aria-hidden="true">
            {%- render 'icons-data',
              width: 9,
              height: 5,
              use_icon: true,
              icon_reference: 'chevron-down',
              section_id: section.id
            -%}
          </i>
        </button>
        <div class="dropdown-component_wrapper dropdown-variant_wrapper" tabindex="-1">
          <ul
            id="cascade-opt2-list-{{ section.id }}"
            class="list-unstyled dropdown-variant_items --align-left"
            role="listbox"
            data-cascade-list="2"
          ></ul>
        </div>
      </dropdown-component>
    </div>
  </div>

  <div
    class="product-custom-cascade_custom-wrap hidden"
    data-cascade-custom-fields
    hidden
  >
    <p class="product-common_variant-title text-size--small --fw-bold product-custom-cascade_custom-heading">
      Enter your custom dimensions
    </p>
    <div class="product-custom-cascade_custom-grid">
      <div class="product-custom-cascade_custom-cell">
        <label class="product-common_variant-title text-size--small --fw-bold" for="cascade-cw-w-{{ section.id }}">
          Width<span class="product-custom-cascade_required" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="cascade-cw-w-{{ section.id }}"
          class="form-control product-custom-cascade_custom-input"
          name="properties[Width]"
          form="{{ form_id }}"
          inputmode="numeric"
          pattern="[0-9]*"
          autocomplete="off"
          disabled
          data-cascade-custom-width
          placeholder="100"
        >
      </div>
      <div class="product-custom-cascade_custom-cell">
        <label class="product-common_variant-title text-size--small --fw-bold" for="cascade-cw-h-{{ section.id }}">
          Height<span class="product-custom-cascade_required" aria-hidden="true">*</span>
        </label>
        <input
          type="text"
          id="cascade-cw-h-{{ section.id }}"
          class="form-control product-custom-cascade_custom-input"
          name="properties[Height]"
          form="{{ form_id }}"
          inputmode="numeric"
          pattern="[0-9]*"
          autocomplete="off"
          disabled
          data-cascade-custom-height
          placeholder="100"
        >
      </div>
      <div class="product-custom-cascade_custom-cell product-custom-cascade_custom-cell--units">
        <label class="product-common_variant-title text-size--small --fw-bold" for="cascade-cw-units-{{ section.id }}">
          Measurement units<span class="product-custom-cascade_required" aria-hidden="true">*</span>
        </label>
        <select
          id="cascade-cw-units-{{ section.id }}"
          class="form-control product-custom-cascade_custom-input"
          name="properties[Measurement units]"
          form="{{ form_id }}"
          disabled
          data-cascade-custom-units
        >
          <option value="mm">mm</option>
          <option value="cm">cm</option>
          <option value="meters">meters</option>
          <option value="in">in</option>
          <option value="ft">ft</option>
        </select>
      </div>
    </div>
    <p
      class="product-custom-cascade_custom-error text-size--small --text-error hidden"
      role="alert"
      data-cascade-custom-error
    ></p>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var sectionId = {{ section.id | json }};
    var soldOutLabel = {{ 'product.atc_buttons.soldout' | t | json }};
    var validationMsg = 'Please enter width and height for your custom size.';
    var validationRangeMsg = 'Width and height must be whole numbers between 100 and 999999999.';
    var root = document.querySelector('.product-custom-cascade-ui[data-cascade-root="' + sectionId + '"]');
    var fullJsonEl = document.getElementById('CustomVariantsFull-' + sectionId);
    if (!root || !fullJsonEl || typeof window.themeOnVariantChange !== 'function') return;

    var customSizeVal = root.getAttribute('data-cascade-custom-o2') || 'Custom size';
    var jsonSelector = root.getAttribute('data-json-selector');
    var formsSelector = root.getAttribute('data-forms');
    var renders = root.getAttribute('data-renders');
    var mainParent = root.getAttribute('data-main-parent');
    var galleries = root.getAttribute('data-galleries');
    var secId = root.getAttribute('data-section-id');
    var productUrl = root.getAttribute('data-product-url');
    var updateUrl = root.getAttribute('data-update-url');

    var customWrap = root.querySelector('[data-cascade-custom-fields]');
    var inpW = root.querySelector('[data-cascade-custom-width]');
    var inpH = root.querySelector('[data-cascade-custom-height]');
    var selU = root.querySelector('[data-cascade-custom-units]');
    var errEl = root.querySelector('[data-cascade-custom-error]');

    var fullVariants;
    try {
      fullVariants = JSON.parse(fullJsonEl.textContent);
    } catch (e) {
      return;
    }
    if (!fullVariants || !fullVariants.length) return;

    var cardJson = document.querySelector(jsonSelector);
    if (!cardJson) return;
    var cardData;
    try {
      cardData = JSON.parse(cardJson.textContent);
    } catch (e) {
      return;
    }
    var cardVariants = cardData.variants || [];

    var opener1 = root.querySelector('[data-cascade-opener="1"]');
    var opener2 = root.querySelector('[data-cascade-opener="2"]');
    var list1 = root.querySelector('[data-cascade-list="1"]');
    var list2 = root.querySelector('[data-cascade-list="2"]');
    if (!opener1 || !opener2 || !list1 || !list2) return;

    var opt1Key = 'option1';
    var opt2Key = 'option2';
    var moneyFormat = window.money_format || {{ shop.money_format | json }};
    var state = { o1: '', o2: '', customModel: null };

    function normOpt2(s) {
      return String(s == null ? '' : s).trim().toLowerCase();
    }

    function opt2MatchesCustomName(opt2) {
      return normOpt2(opt2) === normOpt2(customSizeVal);
    }

    function formatMoney(cents) {
      if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
        return Shopify.formatMoney(cents, moneyFormat);
      }
      return (cents / 100).toFixed(2);
    }

    function uniqueOption1() {
      var seen = {};
      var out = [];
      fullVariants.forEach(function (v) {
        var val = v[opt1Key];
        if (val != null && !seen[val]) {
          seen[val] = true;
          out.push(val);
        }
      });
      return out;
    }

    function variantsForOption1(val) {
      return fullVariants.filter(function (v) {
        return v[opt1Key] === val;
      });
    }

    function widthSort(a, b) {
      var na = parseInt(String(a[opt2Key]), 10);
      var nb = parseInt(String(b[opt2Key]), 10);
      if (!isNaN(na) && !isNaN(nb) && String(na) === String(a[opt2Key]).trim() && String(nb) === String(b[opt2Key]).trim()) {
        return na - nb;
      }
      return String(a[opt2Key]).localeCompare(String(b[opt2Key]), undefined, { numeric: true });
    }

    function option2Label(v) {
      var w = v[opt2Key];
      var side = v[opt1Key];
      var price = formatMoney(v.price);
      return w + ' Wide ' + side + ' - ' + price;
    }

    function customSizeDisplayLabel(side) {
      return customSizeVal + ' — ' + side;
    }

    function labelForVariant(v) {
      if (opt2MatchesCustomName(v[opt2Key])) {
        return customSizeDisplayLabel(v[opt1Key]);
      }
      return option2Label(v);
    }

    function splitTier2Variants() {
      var all = variantsForOption1(state.o1);
      var numeric = [];
      var customVar = null;
      all.forEach(function (v) {
        if (opt2MatchesCustomName(v[opt2Key])) {
          if (!customVar) customVar = v;
        } else {
          numeric.push(v);
        }
      });
      numeric.sort(widthSort);
      return { numeric: numeric, customVar: customVar };
    }

    function buildCustomModel(split) {
      if (split.customVar) return { variant: split.customVar, synthetic: false };
      if (split.numeric.length > 0) return { variant: split.numeric[split.numeric.length - 1], synthetic: true };
      return null;
    }

    function choiceMatchesPreferred(v, pref, customModel) {
      if (pref == null) return false;
      if (customModel && v === customModel.variant && normOpt2(pref) === normOpt2(customSizeVal)) return true;
      return String(v[opt2Key]) === String(pref);
    }

    function findCardVariant(opt1, opt2) {
      return cardVariants.find(function (cv) {
        if (String(cv.option1) !== String(opt1)) return false;
        if (normOpt2(opt2) === normOpt2(customSizeVal) && normOpt2(cv.option2) === normOpt2(customSizeVal)) return true;
        return String(cv.option2) === String(opt2);
      });
    }

    function closeDropdownFrom(node) {
      var dd = node.closest('dropdown-component');
      if (dd && typeof dd.close === 'function') dd.close();
    }

    function isCustomSizeSelected() {
      return normOpt2(state.o2) === normOpt2(customSizeVal);
    }

    function updateCustomPanel() {
      var on = isCustomSizeSelected();
      if (!customWrap || !inpW || !inpH || !selU) return;
      customWrap.classList.toggle('hidden', !on);
      if (on) customWrap.removeAttribute('hidden');
      else customWrap.setAttribute('hidden', '');
      inpW.disabled = !on;
      inpH.disabled = !on;
      selU.disabled = !on;
      if (!on) {
        if (errEl) {
          errEl.classList.add('hidden');
          errEl.textContent = '';
        }
      }
    }

    function applySelection() {
      var errSel = root.getAttribute('data-error-selector');
      if (errSel) {
        var errElem = document.querySelector(errSel);
        if (errElem) errElem.classList.add('hidden');
      }
      var cardMatch;
      if (isCustomSizeSelected() && state.customModel) {
        cardMatch = cardVariants.find(function (cv) {
          return cv.id === state.customModel.variant.id;
        });
      } else {
        cardMatch = findCardVariant(state.o1, state.o2);
      }
      if (!cardMatch || !cardMatch.options) return;
      window.themeOnVariantChange(
        jsonSelector,
        cardMatch.options,
        formsSelector,
        renders,
        mainParent,
        galleries,
        secId,
        productUrl,
        updateUrl,
        null
      );
    }

    function makeItemButton(tier, value, displayText, active, unavailable) {
      var b = document.createElement('button');
      b.type = 'button';
      b.className =
        'dropdown-component_btn-submit product-variant-option_btn-submit --align-left --v-align-middle --word-break product-custom-cascade_dd-item';
      b.setAttribute('data-cascade-tier', tier);
      b.dataset.value = String(value);
      b.dataset.text = displayText;
      b.textContent = displayText;
      if (active) b.classList.add('active');
      if (unavailable) {
        b.disabled = true;
        b.textContent = displayText + ' (' + soldOutLabel + ')';
      }
      return b;
    }

    function renderTier1() {
      list1.innerHTML = '';
      uniqueOption1().forEach(function (val) {
        var li = document.createElement('li');
        li.appendChild(makeItemButton('1', val, val, val === state.o1, false));
        list1.appendChild(li);
      });
      opener1.textContent = state.o1 || '';
    }

    function openerLabelForPick(pick, customModel) {
      if (!pick) return '';
      var base =
        customModel && pick === customModel.variant
          ? customSizeDisplayLabel(pick[opt1Key])
          : labelForVariant(pick);
      return base + (!pick.available ? ' (' + soldOutLabel + ')' : '');
    }

    function fillTier2(preferredWidth) {
      var split = splitTier2Variants();
      var rows = split.numeric;
      var customModel = buildCustomModel(split);
      state.customModel = customModel;

      var choices = rows.slice();
      if (customModel) choices.push(customModel.variant);

      if (choices.length === 0) {
        list2.innerHTML = '';
        opener2.textContent = '';
        state.o2 = '';
        updateCustomPanel();
        return;
      }

      var match =
        preferredWidth != null
          ? choices.find(function (v) {
              return choiceMatchesPreferred(v, preferredWidth, customModel);
            })
          : null;
      var pick = match || choices.find(function (v) {
          return v.available;
        }) || choices[0];

      if (customModel && pick === customModel.variant) {
        state.o2 = customSizeVal;
      } else {
        state.o2 = pick[opt2Key];
      }

      list2.innerHTML = '';

      if (customModel) {
        var liCustom = document.createElement('li');
        var cLabel = customSizeDisplayLabel(customModel.variant[opt1Key]);
        var isPickCustom = pick === customModel.variant;
        liCustom.appendChild(
          makeItemButton(
            '2',
            customSizeVal,
            cLabel,
            isPickCustom && customModel.variant.available,
            !customModel.variant.available
          )
        );
        list2.appendChild(liCustom);
      }

      rows.forEach(function (v) {
        var label = labelForVariant(v);
        var li = document.createElement('li');
        var isPick = pick === v;
        li.appendChild(makeItemButton('2', v[opt2Key], label, isPick && v.available, !v.available));
        list2.appendChild(li);
      });

      opener2.textContent = openerLabelForPick(pick, customModel);
      updateCustomPanel();
    }

    root.addEventListener('click', function (e) {
      var item = e.target.closest('.product-custom-cascade_dd-item');
      if (!item || !root.contains(item) || item.disabled) return;
      e.preventDefault();
      var tier = item.getAttribute('data-cascade-tier');
      if (tier === '1') {
        state.o1 = item.dataset.value;
        renderTier1();
        fillTier2(state.o2);
        applySelection();
        closeDropdownFrom(item);
      } else if (tier === '2') {
        state.o2 = item.dataset.value;
        opener2.textContent = item.textContent.trim();
        list2.querySelectorAll('.product-custom-cascade_dd-item').forEach(function (b) {
          b.classList.toggle(
            'active',
            !b.disabled && normOpt2(b.dataset.value) === normOpt2(state.o2)
          );
        });
        applySelection();
        updateCustomPanel();
        closeDropdownFrom(item);
      }
    });

    function validateCustomDimensions() {
      if (!isCustomSizeSelected()) return true;
      var w = (inpW && inpW.value.trim()) || '';
      var h = (inpH && inpH.value.trim()) || '';
      if (!w || !h) {
        if (errEl) {
          errEl.textContent = validationMsg;
          errEl.classList.remove('hidden');
        }
        return false;
      }
      if (!/^\d+$/.test(w) || !/^\d+$/.test(h)) {
        if (errEl) {
          errEl.textContent = validationRangeMsg;
          errEl.classList.remove('hidden');
        }
        return false;
      }
      var wn = parseInt(w, 10);
      var hn = parseInt(h, 10);
      if (wn < 100 || hn < 100 || wn > 999999999 || hn > 999999999) {
        if (errEl) {
          errEl.textContent = validationRangeMsg;
          errEl.classList.remove('hidden');
        }
        return false;
      }
      if (errEl) {
        errEl.classList.add('hidden');
        errEl.textContent = '';
      }
      return true;
    }

    var form = document.getElementById({{ form_id | json }});
    if (form) {
      form.addEventListener(
        'submit',
        function (e) {
          if (!validateCustomDimensions()) {
            e.preventDefault();
            e.stopImmediatePropagation();
            if (inpW && !inpW.value.trim()) inpW.focus();
            else if (inpH) inpH.focus();
          }
        },
        true
      );
    }

    [inpW, inpH, selU].forEach(function (el) {
      if (!el) return;
      el.addEventListener('input', function () {
        if (errEl) errEl.classList.add('hidden');
      });
      el.addEventListener('change', function () {
        if (errEl) errEl.classList.add('hidden');
      });
    });

    var currentId = form ? parseInt(form.querySelector('input[name="id"]').value, 10) : null;
    var currentFull = fullVariants.find(function (v) {
      return v.id === currentId;
    });
    if (currentFull) {
      state.o1 = currentFull[opt1Key];
      state.o2 = currentFull[opt2Key];
    } else {
      var opts = uniqueOption1();
      state.o1 = opts[0] || '';
    }
    renderTier1();
    fillTier2(currentFull ? currentFull[opt2Key] : null);
  });
</script>
